{
  "name": "easy-dev-proxy",
  "version": "0.1.0",
  "description": "A simple development proxy server with custom routing rules, mock responses, HTTPS interception, and a plugin system",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prebuild": "rm -rf dist",
    "prepack": "npm run build:web && npm run build",
    "prepublishOnly": "npm run build && npm run test",
    "start": "npm run build && node index.js",
    "start:plugin:off": "EP_PLUGIN_MODE=off npm start",
    "start:plugin:shadow": "EP_PLUGIN_MODE=shadow npm start",
    "start:plugin:on": "EP_PLUGIN_MODE=on npm start",
    "smoke:refactor": "node scripts/refactor-smoke.js",
    "drill:rollout": "node scripts/plugin-rollout-drill.js",
    "test": "vitest run",
    "test:identity": "pnpm run build && node scripts/application-identity-smoke.js",
    "test:e2e": "npm run build:web && npm run build && node tests/e2e/interactions.e2e.cjs",
    "test:e2e:rule-drag": "npm run build:web && npm run build && node tests/e2e/rule-drag.e2e.cjs",
    "test:watch": "vitest",
    "test:refactor": "npm run build && node -c index.js && npm test",
    "bench:logs": "node scripts/log-performance-benchmark.js",
    "start:open": "npm run build && node index.js --open",
    "doctor": "node bin/doctor.js",
    "mcp": "node mcp-server.js",
    "build:web": "cd web && pnpm run build",
    "dev:web": "cd web && pnpm run dev",
    "setup:web": "cd web && pnpm install"
  },
  "bin": {
    "ep": "bin/index"
  },
  "files": [
    "bin/",
    "dist/",
    "web/dist/",
    "index.js",
    "mcp-server.js",
    "plugins/",
    "docs/",
    "LICENSE",
    "CONFIG_STRUCTURE.md",
    "README.md"
  ],
  "keywords": [
    "proxy",
    "dev-proxy",
    "mock",
    "https-proxy",
    "debug",
    "development",
    "plugin"
  ],
  "author": "JonathanLee-LX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JonathanLee-LX/easy-proxy.git"
  },
  "homepage": "https://github.com/JonathanLee-LX/easy-proxy#readme",
  "bugs": {
    "url": "https://github.com/JonathanLee-LX/easy-proxy/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "debug": "^4.4.3",
    "esbuild": "^0.27.7",
    "express": "^5.2.1",
    "inquirer": "^8.2.7",
    "node-easy-cert": "^1.3.3",
    "portfinder": "^1.0.38",
    "puppeteer-core": "^24.43.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/node": "^18.19.130",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "nodemon": "^2.0.22",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}