{
  "name": "easy-dev-proxy",
  "version": "1.1.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prebuild": "rm -rf dist",
    "prepack": "npm run build:web && npm run build",
    "start": "npm run build && node index.js",
    "start:plugin:off": "EP_PLUGIN_MODE=off npm start",
    "start:plugin:shadow": "EP_PLUGIN_MODE=shadow npm start",
    "start:plugin:on": "EP_PLUGIN_MODE=on npm start",
    "smoke:refactor": "node scripts/refactor-smoke.js",
    "drill:rollout": "node scripts/plugin-rollout-drill.js",
    "test": "vitest run",
    "test:e2e": "npm run build:web && npm run build && node tests/e2e/interactions.e2e.cjs",
    "test:watch": "vitest",
    "test:refactor": "npm run build && node -c index.js && npm test",
    "prepublish": "npm run build && npm run test",
    "start:open": "npm run build && node index.js --open",
    "doctor": "node bin/doctor.js",
    "mcp": "node mcp-server.js",
    "build:web": "cd web && pnpm run build",
    "dev:web": "cd web && pnpm run dev",
    "postinstall": "cd web && pnpm install && pnpm run build"
  },
  "bin": {
    "ep": "bin/index"
  },
  "files": [
    "bin/",
    "dist/",
    "web/dist/",
    "index.js",
    "proxy-handler.js",
    "proxy-connect.js",
    "proxy-bootstrap.js",
    "mcp-server.js",
    "helpers.js",
    "plugins/",
    "docs/",
    "CLAUDE.md",
    "CONFIG_STRUCTURE.md",
    "README.md"
  ],
  "keywords": [
    "proxy",
    "dev-proxy",
    "mock",
    "https-proxy",
    "debug",
    "development",
    "plugin"
  ],
  "author": "JonathanLee-LX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JonathanLee-LX/easy-proxy.git"
  },
  "homepage": "https://github.com/JonathanLee-LX/easy-proxy#readme",
  "bugs": {
    "url": "https://github.com/JonathanLee-LX/easy-proxy/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "debug": "^4.3.4",
    "esbuild": "^0.27.3",
    "express": "^5.2.1",
    "inquirer": "^8.2.5",
    "node-easy-cert": "^1.3.3",
    "portfinder": "^1.0.32",
    "puppeteer-core": "^24.0.0",
    "ws": "^8.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/node": "^18.19.130",
    "@types/ws": "^8.5.4",
    "@vitest/coverage-v8": "^4.1.0",
    "nodemon": "^2.0.20",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
